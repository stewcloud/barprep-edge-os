BARPREP_SERVER_URL=https://barprep.example.com
BARPREP_EDGE_NAME=BarPrep Edge
BARPREP_EDGE_DATA_DIR=/var/lib/barprep-edge
BARPREP_EDGE_BIND=0.0.0.0
BARPREP_EDGE_PORT=8787
BARPREP_EDGE_LOG_LEVEL=INFO

BARPREP_WIFI_INTERFACE=wlan0
BARPREP_SETUP_SSID_PREFIX=BarPrep-Setup
BARPREP_SETUP_PASSWORD=

BARPREP_PRINTER_DRIVER=brother_ql
BARPREP_PRINTER_MODEL=QL-800
BARPREP_PRINTER_LABEL=62
BARPREP_PRINTER_URI=usb://0x04f9:0x209b

BARPREP_POLL_INTERVAL_SECONDS=2
BARPREP_HEARTBEAT_INTERVAL_SECONDS=20
